// Prisma schema for PK-Referenzen tool.
// Run `npx prisma db push` after editing to sync the local SQLite DB.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  // Local dev uses Postgres too — set DATABASE_URL=postgresql://… in .env
  // or point to a local Docker postgres. SQLite is no longer supported
  // because Render's web service doesn't ship it.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Caregiver {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  formerName  String?
  birthDate   DateTime?
  photoPath   String?
  bio         String?
  languages   String?
  specialties String?

  // German recommendation letter text — generated by AI from the profile
  // and/or written by the user. There is exactly one per caregiver.
  recommendationLetterDe       String?
  recommendationLetterUpdatedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents Document[]
  exports   ExportJob[]
}

// Document type values (SQLite has no enums — validated in app):
//   REFERENZ | ZERTIFIKAT | EMPFEHLUNG | GRUSSKARTE
// Status values: UPLOADED | PROCESSING | READY | ERROR
model Document {
  id          String @id @default(cuid())
  caregiverId String
  caregiver   Caregiver @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  type          String
  title         String
  issuedBy      String?
  issuedAt      DateTime?
  trainingTopic String?

  originalPath String
  originalMime String
  originalLang String?

  translationPath   String?
  translationText   String?
  agencyAttestation String?

  ocrText   String?
  pageCount Int @default(1)

  status String  @default("UPLOADED")
  error  String?

  redactionBoxes RedactionBox[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model RedactionBox {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  page       Int
  x          Float
  y          Float
  width      Float
  height     Float
  source     String   @default("manual") // "manual" | "ai"
  reason     String?
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ExportJob {
  id           String    @id @default(cuid())
  caregiverId  String
  caregiver    Caregiver @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  summaryDraft String?
  summaryFinal String?
  outputPath   String?
  status       String    @default("DRAFT") // DRAFT | RENDERING | READY | ERROR
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
