# Copy to .env and fill in your values.

DATABASE_URL="file:./dev.db"

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# claude-opus-4-7 (highest quality) | claude-sonnet-4-6 (fast/cheap) | claude-haiku-4-5-20251001
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Vision-only override for PII bounding-box detection. Defaults to Opus 4.7
# because precise bbox accuracy matters here; the rest of the pipeline uses
# ANTHROPIC_MODEL above. Set to claude-sonnet-4-6 to save cost.
ANTHROPIC_VISION_MODEL="claude-opus-4-7"

STORAGE_DIR="./storage"

# --- Branding (alles optional, alles per Env überschreibbar) ---
# Tool-UI (Header + Browser-Title):
BRAND_TOOL_NAME="Referenzen-Tool"
BRAND_TOOL_TAGLINE=""

# Exportiertes PDF (Deckblatt-Banner + Footer):
BRAND_PDF_NAME=""
BRAND_PDF_TAGLINE=""
BRAND_PDF_FOOTER_URL=""
# Logo-Pfad relativ zum Projektroot, z.B. "./public/brand/logo.png"
BRAND_PDF_LOGO_PATH=""

# Akzentfarben (Tool + PDF):
BRAND_PRIMARY="#3b3b46"
BRAND_PRIMARY_SOFT="#d6d6dc"
BRAND_PRIMARY_TINT="#eeeef2"
